{
  "name": "rekordbox-exporter",
  "version": "1.0.0",
  "description": "Export Rekordbox playlists to Spotify and Traktor",
  "productName": "FZR Rekordbox Exporter",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "electron:dev": "electron-vite dev",
    "package": "electron-builder",
    "dist": "electron-vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "AlfonsoCifuentes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlfonsoCifuentes/fzr-rekordbox-exporter.git"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "better-sqlite3": "^11.0.0",
    "fast-xml-parser": "^4.4.0",
    "fuse.js": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.fzr.rekordbox-exporter",
    "productName": "FZR Rekordbox Exporter",
    "copyright": "Copyright © 2024 FZR",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map",
      "node_modules/**/*",
      "!node_modules/.cache",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "FZR-Rekordbox-Exporter-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FZR Rekordbox Exporter"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AlfonsoCifuentes",
        "repo": "fzr-rekordbox-exporter"
      }
    ]
  }
}
